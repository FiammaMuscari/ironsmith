# Optional PeerJS signaling server override.
# Leave these unset to use the default PeerJS cloud server.
# VITE_PEER_HOST=0.peerjs.com
# VITE_PEER_PORT=443
# VITE_PEER_PATH=/
# VITE_PEER_KEY=peerjs
# VITE_PEER_SECURE=true

# If PeerJS Cloud disconnects on one of your networks, run `pnpm signal`
# on one machine and point both clients at that server instead.
# Example LAN setup:
# VITE_PEER_HOST=192.168.1.50
# VITE_PEER_PORT=9000
# VITE_PEER_PATH=/peerjs
# VITE_PEER_KEY=peerjs
# VITE_PEER_SECURE=false

# PeerJS client logging: 0 = off, 1 = errors, 2 = warnings, 3 = verbose.
# VITE_PEER_DEBUG=2

# Optional websocket ping interval for the signaling connection, in milliseconds.
# VITE_PEER_PING_INTERVAL=5000

# Optional ICE/TURN config passed directly to RTCPeerConnection.
# This should be a JSON array of RTCIceServer objects.
# Example:
# VITE_PEER_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302","stun:stun1.l.google.com:19302"]},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]

# Optional settings for `pnpm signal`:
# PEER_SERVER_HOST=0.0.0.0
# PEER_SERVER_PORT=9000
# PEER_SERVER_PATH=/peerjs
# PEER_SERVER_KEY=peerjs
# PEER_SERVER_ALLOW_DISCOVERY=false
# PEER_SERVER_PROXIED=false
# PEER_SERVER_CORS=http://192.168.1.50:5173,http://192.168.1.51:5173
